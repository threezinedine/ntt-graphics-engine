{
  "configurations": [
    {
      "name": "Linux",
      "includePath": ["${workspaceFolder}/**"],
      "defines": [
        "NTT_DEBUG",
        "NTT_PLATFORM_UNIX",
        "NTT_STRICT_MEMORY_MANAGEMENT",
        "NTT_ENABLE_ASSERT",
        "NTT_GRAPHICS_DRIVER_GLFW",
        "NTT_GRAPHICS_ENGINE_DIRECTORY=\"${workspaceFolder}\""
      ],
      "compilerPath": "/usr/bin/clang",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "linux-clang-x64"
    }
  ],
  "version": 4
}
