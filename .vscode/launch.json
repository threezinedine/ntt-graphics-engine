{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Engine",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/ntt-graphics-engine",
      "cwd": "${workspaceFolder}/build/debug",
      "preLaunchTask": "Build Engine (Debug)"
    },
    {
      "name": "Editor",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/editor_debug/ntt-graphics-editor",
      "cwd": "${workspaceFolder}/build/editor_debug",
      "preLaunchTask": "Build Editor (Debug)"
    },
    {
      "name": "Tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/tests_debug/ntt-graphics-tests",
      "cwd": "${workspaceFolder}/build/tests_debug",
      "preLaunchTask": "Build Tests (Debug)"
    },
    {
      "name": "Tests (Windows)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/tests_debug/Debug/ntt-graphics-tests.exe",
      "cwd": "${workspaceFolder}/build/tests_debug",
      "console": "integratedTerminal",
      "preLaunchTask": "Build Tests (Debug)"
    }
  ]
}
